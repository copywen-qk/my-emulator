# Makefile for Verilator simulation of RV32IM pipeline with forwarding

VERILATOR = verilator
VERILATOR_FLAGS = -Wall -Wno-fatal -Wno-lint -Wno-style -Wno-width \
                  --cc --exe --build --trace \
                  --top-module rv32im_pipeline_forwarding \
                  -CFLAGS "-std=c++11 -g -O2 -I./include -I./build" \
                  -LDFLAGS "-L./build -lnemu" \
                  --Mdir obj_dir

# Source files
VSRC = vsrc/rv32im_pipeline_forwarding.v
CSRC = csrc/sim_main_forwarding.cpp src/dpi.c

# NEMU library
NEMU_LIB = build/nemu

# Output executable
EXEC = Vrv32im_pipeline_forwarding

# Default target
all: $(EXEC)

# Build NEMU first if needed
$(NEMU_LIB):
	@echo "Building NEMU..."
	cd build && make -f ../Makefile

# Verilator build
$(EXEC): $(VSRC) $(CSRC) $(NEMU_LIB)
	$(VERILATOR) $(VERILATOR_FLAGS) $(VSRC) $(CSRC) -o $(EXEC)
	@echo "Build complete. Run with: ./obj_dir/$(EXEC) <test_file.bin>"

# Clean
clean:
	rm -rf obj_dir/Vrv32im_pipeline_forwarding* $(EXEC)

# Test runs
test_minimal: $(EXEC)
	./obj_dir/$(EXEC) tests/minimal_test.bin

test_forwarding: $(EXEC)
	./obj_dir/$(EXEC) tests/forwarding_test.bin

test_pipeline: $(EXEC)
	./obj_dir/$(EXEC) tests/pipeline_test.bin

# Run all tests
test: test_minimal test_forwarding test_pipeline

.PHONY: all clean test test_minimal test_forwarding test_pipeline