# Makefile for Verilator simulation of RV32IM pipeline with forwarding

VERILATOR = verilator
VERILATOR_FLAGS = -Wall -Wno-fatal -Wno-lint -Wno-style -Wno-width \
                  --cc --exe --build --trace \
                  --top-module rv32im_pipeline_forwarding \
                  -CFLAGS "-std=c++11 -g -O2 -I./include"

# Source files
VSRC = vsrc/rv32im_pipeline_forwarding.v
CSRC = csrc/sim_main_forwarding.cpp csrc/dpi_minimal.c

# Output directory
OBJ_DIR = obj_dir_forwarding

# Default target
all: $(OBJ_DIR)/Vrv32im_pipeline_forwarding

# Verilator build
$(OBJ_DIR)/Vrv32im_pipeline_forwarding: $(VSRC) $(CSRC)
	$(VERILATOR) $(VERILATOR_FLAGS) $(VSRC) $(CSRC) -o $(OBJ_DIR)/Vrv32im_pipeline_forwarding
	@echo "Build complete. Run with: ./$(OBJ_DIR)/Vrv32im_pipeline_forwarding <test_file.bin>"

# Clean
clean:
	rm -rf $(OBJ_DIR)

# Test run
test: $(OBJ_DIR)/Vrv32im_pipeline_forwarding
	./$(OBJ_DIR)/Vrv32im_pipeline_forwarding tests/minimal_test.bin

# Pipeline test
test_pipeline: $(OBJ_DIR)/Vrv32im_pipeline_forwarding
	./$(OBJ_DIR)/Vrv32im_pipeline_forwarding tests/pipeline_test.bin

.PHONY: all clean test test_pipeline