# Verilator configuration
VERILATOR = verilator
VERILATOR_FLAGS = --cc --exe --build -j 0 -Wall \
	-CFLAGS "-DCONFIG_VERILATOR -I../include $(shell sdl2-config --cflags)" \
	-LDFLAGS "$(shell sdl2-config --libs)" \
	-Iinclude

# Sources
VSRC = vsrc/dummy_cpu.v
CSRC = csrc/sim_main.cpp src/main.c src/memory.c src/device.c
VOBJS = obj_dir/Vdummy_cpu

.PHONY: sim run clean

sim: $(VOBJS)

$(VOBJS): $(VSRC) $(CSRC)
	$(VERILATOR) $(VERILATOR_FLAGS) $(VSRC) $(CSRC)

run: sim
	./obj_dir/Vdummy_cpu tests/dummy.bin

clean:
	rm -rf obj_dir
