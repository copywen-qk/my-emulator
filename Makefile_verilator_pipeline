# Verilator configuration for RV32IM Pipeline CPU
VERILATOR = verilator
VERILATOR_FLAGS = --cc --exe --build -j 0 -Wall \
	-CFLAGS "-DCONFIG_VERILATOR -I../include $(shell sdl2-config --cflags)" \
	-LDFLAGS "$(shell sdl2-config --libs)" \
	--top-module rv32im_pipeline_cpu \
	-Iinclude

# Sources
VSRC = vsrc/rv32im_pipeline_cpu.v
CSRC = csrc/sim_main_new.cpp src/main.c src/memory.c src/device.c src/dpi.c
VOBJS = obj_dir_pipeline/Vrv32im_pipeline_cpu

.PHONY: sim run clean

sim: $(VOBJS)

$(VOBJS): $(VSRC) $(CSRC)
	$(VERILATOR) $(VERILATOR_FLAGS) $(VSRC) $(CSRC) --Mdir obj_dir_pipeline

run: sim
	./obj_dir_pipeline/Vrv32im_pipeline_cpu tests/minimal_test.bin

clean:
	rm -rf obj_dir_pipeline

# Test targets
test-minimal: sim
	@echo "Running minimal test..."
	./obj_dir_pipeline/Vrv32im_pipeline_cpu tests/minimal_test.bin

test-simple: sim
	@echo "Running simple test..."
	./obj_dir_pipeline/Vrv32im_pipeline_cpu tests/simple_test.bin

test-dummy: sim
	@echo "Running dummy test..."
	./obj_dir_pipeline/Vrv32im_pipeline_cpu tests/dummy.bin

# Debug target
debug: sim
	@echo "Running with debug output..."
	./obj_dir_pipeline/Vrv32im_pipeline_cpu tests/minimal_test.bin 2>&1 | head -50