# Makefile for Verilator simulation of RV32IM pipeline with forwarding

VERILATOR = verilator
VERILATOR_FLAGS = -Wall -Wno-fatal -Wno-lint -Wno-style -Wno-width \
                  --cc --exe --build --trace \
                  --top-module rv32im_pipeline_forwarding \
                  -CFLAGS "-std=c++11 -g -O2 -I./include" \
                  --Mdir obj_dir

# Source files
VSRC = vsrc/rv32im_pipeline_forwarding.v
CSRC = csrc/sim_main_forwarding.cpp src/dpi.c

# Output executable
EXEC = obj_dir/Vrv32im_pipeline_forwarding

# Default target
all: $(EXEC)

# Verilator build
$(EXEC): $(VSRC) $(CSRC)
	$(VERILATOR) $(VERILATOR_FLAGS) $(VSRC) $(CSRC) -o $(EXEC)
	@echo "Build complete. Run with: ./$(EXEC) <test_file.bin>"

# Clean
clean:
	rm -rf obj_dir/Vrv32im_pipeline_forwarding*

# Test run
test: $(EXEC)
	./$(EXEC) tests/minimal_test.bin

# Forwarding test
test_forwarding: $(EXEC)
	./$(EXEC) tests/forwarding_test.bin

# Pipeline test
test_pipeline: $(EXEC)
	./$(EXEC) tests/pipeline_test.bin

.PHONY: all clean test test_forwarding test_pipeline