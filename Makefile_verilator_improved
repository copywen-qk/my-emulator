# Makefile for Verilator simulation of improved RV32IM pipeline

VERILATOR = verilator
VERILATOR_FLAGS = -Wall -Wno-fatal -Wno-lint -Wno-style -Wno-width \
                  --cc --exe --build \
                  --top-module rv32im_pipeline_improved \
                  -CFLAGS "-std=c++11 -g -O2 -I./include" \
                  --Mdir obj_dir_improved

# Source files
VSRC = vsrc/rv32im_pipeline_improved.v
CSRC = csrc/sim_main_new.cpp src/dpi.c

# Output executable
EXEC = obj_dir_improved/Vrv32im_pipeline_improved

# Default target
all: $(EXEC)

# Verilator build
$(EXEC): $(VSRC) $(CSRC)
	@mkdir -p obj_dir_improved
	$(VERILATOR) $(VERILATOR_FLAGS) $(VSRC) $(CSRC) -o $(EXEC)
	@echo "Build complete. Run with: ./$(EXEC) <test_file.bin>"

# Clean
clean:
	rm -rf obj_dir_improved

# Test runs
test_minimal: $(EXEC)
	./$(EXEC) tests/minimal_test.bin

test_simple: $(EXEC)
	./$(EXEC) tests/simple_pipeline_test.bin

test_forwarding: $(EXEC)
	./$(EXEC) tests/forwarding_test.bin

# Run all tests
test: test_minimal test_simple test_forwarding

.PHONY: all clean test test_minimal test_simple test_forwarding